# Local dev: optional override (default is http://localhost:8000/api).
# VITE_API_URL=http://localhost:8000/api

# Production (Vercel): leave unset to use the built-in Render URL in code, or set explicitly:
# VITE_API_URL=https://your-service.onrender.com/api

# If Vercel rewrites /api → Render and vercel.json is in the deploy root, you can use:
# VITE_API_URL=/api
